{
  "expo": {
    "name": "DataCollect",
    "slug": "thyform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/thyicn1.png",
    "scheme": "thyform",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F5DC",
        "foregroundImage": "./assets/images/thyicn1.png",
        "monochromeImage": "./assets/images/thyicn2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kitarajumgonja.datacollect"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/thyicn1.png"
    },
    "plugins": [
      "expo-router"
      
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f1c5de9-9a95-4aa0-90e9-b1865dc3eaa5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1f1c5de9-9a95-4aa0-90e9-b1865dc3eaa5",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
